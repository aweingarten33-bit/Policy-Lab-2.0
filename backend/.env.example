# ── LLM Provider API Keys ──
# Set at least one. The cascade tries all configured keys in order.
ANTHROPIC_API_KEY=      # console.anthropic.com — paid, primary: Claude Opus 4.8, best calibration/lowest hallucination rate
OPENAI_API_KEY=         # platform.openai.com — paid, fallback
GROQ_API_KEY=           # console.groq.com — free, fastest, fallback
GEMINI_API_KEY=         # aistudio.google.com — free tier, fallback
MISTRAL_API_KEY=        # console.mistral.ai — free tier, fallback
OPENROUTER_API_KEY=     # openrouter.ai — free models available, fallback

# ── API Security ──
# Optional. If set, all non-public endpoints require: x-api-key: <this value>
API_KEY=

# ── CORS ──
# In production, set to your Vercel frontend URL (comma-separated for multiple).
# Example: https://your-app.vercel.app
CORS_ORIGINS=*

# ── App Settings ──
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# ── Knowledge Base ──
# Railway provides a persistent volume — mount it at /data and set this path.
KB_PERSIST_DIR=./knowledge_base
KB_AUTO_SEED=true
KB_ENABLED=true

# ── Live Research ──
LIVE_RESEARCH_ENABLED=true
LIVE_RESEARCH_MAX_RESULTS=5
